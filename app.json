{
  "expo": {
    "name": "BeReal",
    "slug": "bereal-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "berealclone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/bereal-icon.png",
      "infoPliat": {
        "NSPhotoLibraryUsageDescription": "We need access your photo library so you can choose photos to upload",
        "NSCameraUsageDescription": "We need access your camera so you can choose photos to upload"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.berealclone"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
